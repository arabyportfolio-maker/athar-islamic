# ============================================================
# Athar Islamic — Environment Variables
# نسخ هذا الملف إلى .env.local وعدّل القيم
# ============================================================

# ─── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role (للـ Edge Functions فقط — لا تضعه في Frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Application ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://athar-islamic.com
NEXT_PUBLIC_APP_NAME=أثر إسلامي

# اللغة الافتراضية (ar | en | fr | tr | id)
NEXT_PUBLIC_DEFAULT_LOCALE=ar

# ─── Analytics ────────────────────────────────────────────
# PostHog
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Monitoring ───────────────────────────────────────────
# Sentry
SENTRY_DSN=https://YOUR_KEY@sentry.io/YOUR_PROJECT_ID
SENTRY_ORG=your-org
SENTRY_PROJECT=athar-islamic

# ─── AI (V3+) ─────────────────────────────────────────────
# OpenAI (للـ Athar AI Assistant)
OPENAI_API_KEY=sk-...

# ─── Prayer Times API ─────────────────────────────────────
# Aladhan API (مجانية)
PRAYER_API_URL=https://api.aladhan.com/v1

# ─── Email (للإشعارات) ────────────────────────────────────
# Resend
RESEND_API_KEY=re_...

# ─── QR Code ──────────────────────────────────────────────
NEXT_PUBLIC_QR_BASE_URL=https://athar-islamic.com/memorial
